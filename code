                "strawberry": "🍓",
                "grapes": "🍇",
                "mango": "🥭",
                "pencil": "✏",
                "100":"💯",
                "cute":"🩷",
                "funny":"😜",
                "smile":"😀",
                "excited":"🤩",
                "pleading":"🥺",
                "hand":"💪",
                "brain":"🧠",
                "moon":"🌝",
                "fire":"🔥",
                "seenoevil":"🙈",
                "hearnoevil":"🙉",
                "speaknoevil":"🙊",
                "music":"🎶",
                "sunflower": "🌻",
                "angel":"😇",
                "i":"I",
                "halloween":"🎃",
                "love you":"🫶",
                "writting":"✍",
                "peacock":"🦚",
                "rose":"🌹",
                "pregnant":"🤰",
                "lotus":"🪷",
                "morning":"🌄",
