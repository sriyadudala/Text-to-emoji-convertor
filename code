                "biryani":"🍲",
                "popcorn":"🍿",
                "fear":"😱",
                "book":"📗",
                "readingbook":"📖",
                "books":"📚"
            };

            // Split the text into words, handle punctuation and convert to lowercase
            const words = text.split(/\s+/).map(word => word.replace(/[^a-zA-Z0-9]/g, '').toLowerCase());

            // Replace words with emojis if they exist in the dictionary
            const convertedText = words.map(word => emojiDictionary[word] || word).join(' ');

            // Display the converted text with emojis
            document.getElementById('emojiTextDisplay').textContent = convertedText;
        }
    </script>

</body>
</html
