                "boy": "👦🏻",
                "men": "👨🏻",
                "doctor": "👩🏻‍⚕",
                "cook": "👩🏻‍🍳",
                "lawyer": "👩🏻‍🎓",
                "teacher": "🧑🏻‍🏫",
                "santa": "🎅🏻",
                "princess": "👸🏻",
                "prince": "🤴🏻",
                "dancing": "💃🏻",
                "ring": "💍",
                "rat": "🐭",
                "panda": "🐼",
                "pig": "🐷",
                "monkey": "🐒",
                "horse": "🐴",
                "butterfly": "🦋",
                "diamond": "💎",
                "knife": "🔪",
