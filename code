                "laughing": "😂",
                "romantic love": "🥰",
                "affection": "😙",
                "joy": "🥳",
                "angry": "😡",
                "cold": "🥶",
                "thinking": "🤔",
                "flirting": "🙃",
                "salute": "🫡",
                "quiet": "🤫",
                "fever": "🤒",
                "joker": "🤡",
                "ghost": "👻",
                "clapping": "👏🏻",
                "shakehand": "🤝",
                "like": "👍🏻",
                "dislike": "👎🏻",
                "punch": "👊🏻",
                "please": "🤌🏻",
                "super": "👌🏻",
                "namaste": "🙏🏻",
                "blessings": "🙌🏻",
                "slap": "👋🏻",
                "leg": "🦵🏻",
                "lipstick": "💄",
